        <mxCell id="m4" value="4. suspend_tenant(tenant_id, session, cache)" style="endArrow=block;endFill=1;html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="245" y="230" as="sourcePoint"/><mxPoint x="635" y="230" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m5" value="5. update(tenant_id, {is_active: False})" style="endArrow=block;endFill=1;html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="635" y="265" as="sourcePoint"/><mxPoint x="840" y="265" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m6" value="6. UPDATE tenants SET is_active=false WHERE id=:id" style="endArrow=block;endFill=1;html=1;fontSize=10;strokeColor=#9673a6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="840" y="295" as="sourcePoint"/><mxPoint x="1055" y="295" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m7" value="7. OK" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;strokeColor=#9673a6;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1055" y="325" as="sourcePoint"/><mxPoint x="840" y="325" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m8" value="8. SET tenant:{tenant_id}:status = suspended (TTL 30s)" style="endArrow=block;endFill=1;html=1;fontSize=10;strokeColor=#b85450;fontStyle=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="635" y="365" as="sourcePoint"/><mxPoint x="1265" y="365" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m9" value="9. OK" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;strokeColor=#b85450;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1265" y="395" as="sourcePoint"/><mxPoint x="635" y="395" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m10" value="10. TenantAdminRead {is_active: false}" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="635" y="435" as="sourcePoint"/><mxPoint x="245" y="435" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m11" value="11. HTTP 200 {is_active: false}" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;fontStyle=1;strokeColor=#82b366;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="245" y="470" as="sourcePoint"/><mxPoint x="70" y="470" as="targetPoint"/></mxGeometry></mxCell>

        <!-- Tenant request después de suspensión -->
        <mxCell id="sep" value="" style="line;strokeColor=#999;dashed=1;" vertex="1" parent="1"><mxGeometry x="20" y="495" width="1330" height="10" as="geometry"/></mxCell>
