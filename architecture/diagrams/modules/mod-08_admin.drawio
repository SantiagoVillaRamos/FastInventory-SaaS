        <mxCell id="tu" value="Usuario del Tenant" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="1"><mxGeometry x="20" y="535" width="110" height="35" as="geometry"/></mxCell>
        <mxCell id="m12" value="GET /products/ (Bearer JWT del tenant suspendido)" style="endArrow=block;endFill=1;html=1;fontSize=10;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="130" y="555" as="sourcePoint"/><mxPoint x="245" y="555" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m13" value="get_current_tenant() → GET tenant:{id}:status → 'suspended'" style="endArrow=block;endFill=1;html=1;fontSize=10;strokeColor=#b85450;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="245" y="585" as="sourcePoint"/><mxPoint x="1265" y="585" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m14" value="HTTP 403 'Tu negocio ha sido suspendido'" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;fontStyle=1;strokeColor=#b85450;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="245" y="615" as="sourcePoint"/><mxPoint x="130" y="615" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="note" value="HU-16: Efecto en ≤30s (TTL Redis = 30s)&#xa;Aplica a todos los workers Uvicorn simultáneamente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="1150" y="490" width="200" height="60" as="geometry"/></mxCell>
