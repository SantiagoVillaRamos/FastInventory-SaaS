        <mxCell id="M1b" value="+ tenant_id: UUID (FK→tenants)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;fontStyle=1;" vertex="1" parent="M1"><mxGeometry y="62" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M1c" value="+ seller_id: UUID (FK→users)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M1"><mxGeometry y="84" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M1d" value="+ total: DECIMAL(10,2)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M1"><mxGeometry y="106" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M1e" value="+ created_at: DateTime" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M1"><mxGeometry y="128" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M1n" value="1:N → SaleItem" style="text;strokeColor=none;fillColor=#fffacd;align=center;fontSize=10;fontStyle=2;" vertex="1" parent="M1"><mxGeometry y="152" width="255" height="16" as="geometry"/></mxCell>

        <!-- SaleItem Model -->
        <mxCell id="M2" value="«entity» SaleItem (models.py)" style="swimlane;fontStyle=1;startSize=30;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="20" y="265" width="255" height="200" as="geometry"/></mxCell>
