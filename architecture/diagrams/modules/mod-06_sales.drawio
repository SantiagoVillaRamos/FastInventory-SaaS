        <!-- SaleItemInput -->
        <mxCell id="SI" value="«schema» SaleItemInput" style="swimlane;fontStyle=3;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="730" y="240" width="230" height="100" as="geometry"/></mxCell>
        <mxCell id="SIdiv" value="" style="line;strokeColor=#d6b656;" vertex="1" parent="SI"><mxGeometry y="30" width="230" height="10" as="geometry"/></mxCell>
        <mxCell id="SIa" value="+ product_id: UUID" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="SI"><mxGeometry y="40" width="230" height="22" as="geometry"/></mxCell>
        <mxCell id="SIb" value="+ quantity: int (≥1)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="SI"><mxGeometry y="62" width="230" height="22" as="geometry"/></mxCell>

        <!-- Arrows -->
        <mxCell id="A1" value="1:N" style="endArrow=ERmany;startArrow=ERone;html=1;fontSize=10;" edge="1" source="M1" target="M2" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="A2" value="usa" style="endArrow=open;endFill=0;dashed=1;html=1;fontSize=10;" edge="1" source="S1" target="R1" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
