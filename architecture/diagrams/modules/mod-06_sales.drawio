        <mxCell id="M2b" value="+ sale_id: UUID (FK→sales)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M2"><mxGeometry y="62" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M2c" value="+ tenant_id: UUID (FK→tenants)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;fontStyle=1;" vertex="1" parent="M2"><mxGeometry y="84" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M2d" value="+ product_id: UUID (FK→products)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M2"><mxGeometry y="106" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M2e" value="+ quantity: INTEGER" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M2"><mxGeometry y="128" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M2f" value="+ unit_price: DECIMAL(10,2)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M2"><mxGeometry y="150" width="255" height="22" as="geometry"/></mxCell>
        <mxCell id="M2n" value="tenant_id duplicado para integridad de aislamiento" style="text;strokeColor=none;fillColor=#fffacd;align=center;fontSize=10;fontStyle=2;" vertex="1" parent="M2"><mxGeometry y="172" width="255" height="22" as="geometry"/></mxCell>

        <!-- SaleService -->
        <mxCell id="S1" value="SaleService (service.py)" style="swimlane;fontStyle=1;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="330" y="60" width="340" height="185" as="geometry"/></mxCell>
        <mxCell id="S1div" value="" style="line;strokeColor=#b85450;" vertex="1" parent="S1"><mxGeometry y="30" width="340" height="10" as="geometry"/></mxCell>
        <mxCell id="S1a" value="+ create_sale(tenant, seller_id, items, session, cache)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="S1"><mxGeometry y="40" width="340" height="22" as="geometry"/></mxCell>
