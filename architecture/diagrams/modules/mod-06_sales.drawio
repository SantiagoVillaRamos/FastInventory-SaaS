        <mxCell id="S1c" value="+ list_sales(tenant_id, from_date, session)" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="S1"><mxGeometry y="84" width="340" height="22" as="geometry"/></mxCell>
        <mxCell id="S1n" value="⚡ create_sale() usa async with session.begin()&#xa;ROLLBACK automático si Stock insuficiente o producto&#xa;no pertenece al tenant (verifica tenant_id en cada ítem)" style="text;strokeColor=none;fillColor=#f8cecc;align=center;fontSize=10;fontStyle=2;" vertex="1" parent="S1"><mxGeometry y="115" width="340" height="55" as="geometry"/></mxCell>

        <!-- SaleRepository -->
        <mxCell id="R1" value="SaleRepository (repository.py)" style="swimlane;fontStyle=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="730" y="60" width="330" height="140" as="geometry"/></mxCell>
