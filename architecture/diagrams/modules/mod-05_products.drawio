        <mxCell id="R1" value="ProductRepository (repository.py)" style="swimlane;fontStyle=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="700" y="60" width="350" height="255" as="geometry"/></mxCell>
