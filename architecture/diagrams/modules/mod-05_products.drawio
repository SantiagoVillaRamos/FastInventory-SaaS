        <!-- ProductService -->
        <mxCell id="S1" value="ProductService (service.py)" style="swimlane;fontStyle=1;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="340" y="60" width="310" height="185" as="geometry"/></mxCell>
