        <mxCell id="M1e" value="+ description: TEXT" style="text;strokeColor=none;fillColor=none;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="M1"><mxGeometry y="128" width="270" height="22" as="geometry"/></mxCell>
