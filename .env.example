# =====================================================
# FastInventory SaaS — Variables de Entorno
# Copia este archivo como .env y rellena los valores
# =====================================================

# ENTORNO
ENVIRONMENT=dev   # dev | prod

# SEGURIDAD
# En producción: genera con: openssl rand -hex 32
SECRET_KEY=CAMBIA_ESTO_EN_PRODUCCION_usa_openssl_rand_-hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# BASE DE DATOS PostgreSQL
DATABASE_URL=postgresql+asyncpg://fastinventory_user:fastinventory_pass@postgres:5432/fastinventory_db

# REDIS
REDIS_URL=redis://redis:6379/0

# CORS (en producción, especifica tu dominio: https://tudominio.com)
CORS_ORIGINS=["*"]

# POSTGRESQL (usado por Docker Compose)
POSTGRES_USER=fastinventory_user
POSTGRES_PASSWORD=fastinventory_pass
POSTGRES_DB=fastinventory_db
